# macOS
.DS_Store

# SwiftPM
.build/
.swiftpm/
Package.resolved
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Build outputs
dist/

# Local module cache used by scripts/package-app.sh
**/module-cache/

# Design assets workspace (uploads, exports). Treat as untracked so
# git add -A doesn't sweep large binary blobs into source commits.
CrateDigger_DESIGN/

# Local secrets (Last.fm API credentials, etc.) consumed at package time.
# Never commit these — see scripts/lastfm.env.example.
scripts/.lastfm.env
.env
.env.local

# Claude Code local session state (permissions, worktrees).
.claude/
