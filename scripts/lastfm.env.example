# Last.fm API credentials for release packaging.
#
# Copy this file to scripts/.lastfm.env (which is gitignored) and fill in your
# own application API key + shared secret from https://www.last.fm/api/account/create
# scripts/package-app.sh sources scripts/.lastfm.env automatically and embeds
# these into the packaged app's Info.plist.
#
# These are *application* credentials, never the user's account login. They are
# intentionally not committed — keep them out of source control. For a `swift run`
# dev build, export the same variables in your shell instead.

export CRATEDIGGER_LASTFM_API_KEY="your-lastfm-api-key"
export CRATEDIGGER_LASTFM_API_SECRET="your-lastfm-shared-secret"
